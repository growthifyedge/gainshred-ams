# ---------------------------------------------------------------------------
# GainShred AMS — environment variables
# Copy this file to ".env.local" and fill in your real Supabase values.
# Find them in: Supabase Dashboard -> Project Settings -> API
#
# BOTH of these are PUBLIC values (they are bundled into the browser app).
# Your data is protected by Row Level Security in the database, NOT by hiding
# these keys. NEVER put the Supabase "service_role" key or your database
# password in this app or in Git.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
